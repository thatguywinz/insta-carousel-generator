# ==========================================================================
# insta-carousel-generator — environment variables (PLACEHOLDERS ONLY)
# Never place real secrets in this file. Real values are injected by the
# Claude Max Remote Routine environment at runtime.
# ==========================================================================

# --- Google Sheets (ideas queue / settings / tracker) ---
GOOGLE_SHEET_ID=your-google-sheet-id
# Base64-encoded service-account JSON (single line, no newlines)
GOOGLE_SERVICE_ACCOUNT_B64=base64-encoded-service-account-json

# --- Cloudflare R2 (S3-compatible object storage) ---
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_PUBLIC_BUCKET=your-public-bucket-name
R2_PRIVATE_BUCKET=your-private-bucket-name
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://media.example.com

# --- Instagram (official Graph API with Instagram Login) ---
INSTAGRAM_ACCESS_TOKEN=your-long-lived-instagram-user-token
INSTAGRAM_USER_ID=your-instagram-professional-account-id
META_GRAPH_API_VERSION=v21.0

# --- Security / runtime ---
# 32-byte key, base64 or hex encoded, used for AES-256-GCM token encryption
TOKEN_ENCRYPTION_KEY=base64-or-hex-encoded-32-byte-key
TIMEZONE=America/Toronto
NODE_ENV=production
